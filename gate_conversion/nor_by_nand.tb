module nor_by_nand_tb;

reg a,b;
wire y;

nor_by_nand DUT(.a(a), .b(b), .y(y));

initial begin

    $dumpfile("dump.vcd");
    $dumpvars(1);

    $monitor("a=%b b=%b y=%b", a,b,y);

    a=0; b=0;
    #10;

    a=0; b=1;
    #10;

    a=1; b=0;
    #10;

    a=1; b=1;
    #10;

    $finish;

end

endmodule
